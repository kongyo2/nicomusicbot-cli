{
  "name": "@kongyo2/nicomusicbot",
  "version": "0.1.3",
  "description": "Ink-powered TypeScript port of NicomusicBot for Discord voice playback from NicoNico.",
  "license": "Unlicense",
  "type": "module",
  "bin": {
    "nicomusicbot": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "dev": "tsx src/cli.tsx",
    "start": "node dist/cli.js",
    "lint": "oxlint --silent src",
    "lint:strict": "oxlint --deny-warnings src",
    "check:file": "prettier --check",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "discord",
    "niconico",
    "ink",
    "cli",
    "music-bot",
    "typescript"
  ],
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@inkjs/ui": "^2.0.0",
    "discord.js": "^14.26.2",
    "ink": "^7.0.0",
    "neverthrow": "^8.2.0",
    "opusscript": "^0.0.8",
    "react": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "oxlint": "^1.59.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kongyo2/nicomusicbot-cli.git"
  },
  "homepage": "https://github.com/kongyo2/nicomusicbot-cli#readme",
  "bugs": {
    "url": "https://github.com/kongyo2/nicomusicbot-cli/issues"
  }
}
