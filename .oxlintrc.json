{
  "$schema": "https://oxc.rs/oxlint/configuration/schema.json",
  "plugins": ["import", "node", "promise", "typescript"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "typescript/no-explicit-any": "error"
  },
  "ignorePatterns": ["node_modules", "dist", "coverage"]
}
